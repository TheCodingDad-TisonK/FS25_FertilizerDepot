<?xml version="1.0" encoding="utf-8" standalone="no"?>
<placeable type="fertilizerDepotType">

    <storeData>
        <name>Fertilizer Depot</name>
        <functions>
            <function>Buy, store, and sell fertilizers</function>
        </functions>
        <image>store/store_depot.dds</image>
        <price>25000</price>
        <dailyUpkeep>50</dailyUpkeep>
        <lifetime>1000</lifetime>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
    </storeData>

    <!--
        Use the vanilla limeStation building for visual + collision.
        It already has a vehicle loading trigger and a player refill trigger,
        plus proper clear/level/test areas and PBR textures.
        $data = game data root (equivalent of $dataS in Lua).
    -->
    <base>
        <filename>$data/placeables/brandless/limeStation/limeStation.i3d</filename>
        <canBeDeleted>true</canBeDeleted>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart" endNode="testAreaEnd"/>
        </testAreas>
        <sounds>
            <place template="smallImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart" widthNode="clearAreaWidth"
                   heightNode="clearAreaHeight"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="1" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart" widthNode="levelAreaWidth"
                       heightNode="levelAreaHeight" groundType="gravel"/>
        </levelAreas>
    </leveling>

    <!-- Custom specialization: hook our trigger nodes from the limeStation i3d -->
    <fertilizerDepot vehicleTrigger="vehicleTrigger" playerTrigger="playerTrigger"/>

    <!-- Map hotspot -->
    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="mapHotspot"/>
    </hotspots>

    <i3dMappings>
        <!--
          limeStation.i3d root children (0-based):
            [0] clearAreas
            [1] levelAreas
            [2] testAreas
            [3] tipOcclusionUpdateAreas
            [4] buyingStation
                  [0] teleportNode
                  [1] markerLoading
                  [2] mapPosition          ← map hotspot anchor
                  [3] loadingStation
                        [0] loadingTrigger ← vehicle trigger (mask=trailers)
            [5] silo
                  [0] unloadingStation
                  [1] loadingStation
                  [2] refillPlayerTrigger  ← player trigger (mask=player)
            [6] visuals                    ← building mesh (PBR, GIANTS textures)
            [7] collisions                 ← building collision mesh
        -->

        <!-- Our trigger nodes -->
        <i3dMapping id="vehicleTrigger" node="0>4|3|0"/>
        <i3dMapping id="playerTrigger"  node="0>5|2"/>

        <!-- Map hotspot -->
        <i3dMapping id="mapHotspot"     node="0>4|2"/>

        <!-- Placement / clear / level areas -->
        <i3dMapping id="clearAreaStart"  node="0>0|0"/>
        <i3dMapping id="clearAreaWidth"  node="0>0|0|0"/>
        <i3dMapping id="clearAreaHeight" node="0>0|0|1"/>

        <i3dMapping id="levelAreaStart"  node="0>1|0"/>
        <i3dMapping id="levelAreaWidth"  node="0>1|0|0"/>
        <i3dMapping id="levelAreaHeight" node="0>1|0|1"/>

        <i3dMapping id="testAreaStart"   node="0>2|0"/>
        <i3dMapping id="testAreaEnd"     node="0>2|0|0"/>
    </i3dMappings>

</placeable>
