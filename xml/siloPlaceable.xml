<?xml version="1.0" encoding="utf-8" standalone="no"?>
<placeable type="fertilizerSiloType">

    <storeData>
        <name>$l10n_fd_silo_name</name>
        <functions>
            <function>$l10n_fd_silo_function</function>
        </functions>
        <image>icon.dds</image>
        <price>15000</price>
        <dailyUpkeep>25</dailyUpkeep>
        <lifetime>1000</lifetime>
        <brand>NONE</brand>
        <species>placeable</species>
        <category>productionPoints</category>
        <canBeSold>true</canBeSold>
        <showInStore>true</showInStore>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
    </storeData>

    <base>
        <filename>i3d/multifruitstation.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <!-- Keep buying pipe only (0>4). Delete all other functional groups.  -->
    <!-- Node indices verified against multifruitstation.i3d scene tree:  -->
    <!--   0>5  = silo functional group (nodeId 105)                      -->
    <!--   0>10 = warningStripes (nodeId 204)                             -->
    <!--   0>11 = sellingStation (nodeId 207)                             -->
    <!--   0>12 = warehouse (nodeId 213)                                  -->
    <deletedNodes>
        <deletedNode node="0>5"/>
        <deletedNode node="0>10"/>
        <deletedNode node="0>11"/>
        <deletedNode node="0>12"/>
    </deletedNodes>

    <!-- Custom silo specialization: registers with DepotManager for pre-order fill flow -->
    <fertilizerSilo loadingStation="loadingStation_0"/>

    <placement useRandomYRotation="false" useManualYRotation="true">
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01"/>
        </testAreas>
        <sounds>
            <place template="smallImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="1" maxSlope="75" maxEdgeAngle="30">
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01"
                       heightNode="levelAreaHeight01" groundType="asphalt"/>
        </levelAreas>
    </leveling>

    <indoorAreas/>

    <lights>
        <group weatherRequiredFlags="NIGHT"/>
        <sharedLight filename="$data/shared/assets/lights/rudolfHormann/light150.xml"
                     linkNode="light150_0" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 55"/>
        </sharedLight>
        <sharedLight filename="$data/shared/assets/lights/rudolfHormann/light150.xml"
                     linkNode="light150_1" groupIndex="1">
            <rotationNode name="rotationNode01" rotation="0 0 55"/>
        </sharedLight>
        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
            </high>
        </realLights>
    </lights>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01"/>
        </updateAreas>
    </ai>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01"
                                endNode="tipOcclusionUpdateAreaEnd01"/>
    </tipOcclusionUpdateAreas>

    <hotspots>
        <hotspot type="LOADING" linkNode="mapPosition" teleportNode="teleportNode"/>
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="markerLoading"
                       filename="$data/shared/assets/marker/markerIconLoad.i3d"/>
    </triggerMarkers>

    <i3dMappings>
        <!-- Clear / level areas -->
        <i3dMapping id="clearAreaStart01"  node="0>0|0"/>
        <i3dMapping id="clearAreaWidth01"  node="0>0|0|0"/>
        <i3dMapping id="clearAreaHeight01" node="0>0|0|1"/>

        <i3dMapping id="levelAreaStart01"  node="0>1|0"/>
        <i3dMapping id="levelAreaWidth01"  node="0>1|0|0"/>
        <i3dMapping id="levelAreaHeight01" node="0>1|0|1"/>

        <!-- Test areas -->
        <i3dMapping id="testAreaStart01" node="0>2|0"/>
        <i3dMapping id="testAreaEnd01"   node="0>2|0|0"/>

        <!-- Tip occlusion -->
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>3|0"/>
        <i3dMapping id="tipOcclusionUpdateAreaEnd01"   node="0>3|0|0"/>

        <!-- Buying station nodes -->
        <i3dMapping id="buyingStation"    node="0>4"/>
        <i3dMapping id="teleportNode"     node="0>4|0"/>
        <i3dMapping id="markerLoading"    node="0>4|1"/>
        <i3dMapping id="mapPosition"      node="0>4|2"/>
        <i3dMapping id="loadingStation_0" node="0>4|3"/>
        <i3dMapping id="loadingTrigger"   node="0>4|3|0"/>
        <i3dMapping id="dischargeNode"    node="0>4|3|1"/>
        <i3dMapping id="aiNodeLoading"    node="0>4|3|2"/>
        <i3dMapping id="pipeEffect"       node="0>4|3|3|0"/>
        <i3dMapping id="pipeEffectSmoke"  node="0>4|3|3|1"/>

        <!-- Lights -->
        <i3dMapping id="light150_0"    node="0>9|0|0"/>
        <i3dMapping id="light150_1"    node="0>9|0|1"/>
        <i3dMapping id="realLightsLow"  node="0>9|0|4|0"/>
        <i3dMapping id="realLightsHigh" node="0>9|0|4|1"/>
    </i3dMappings>

</placeable>
