                <Text    profile="fdTabText" id="tabBuyText" position="0px 0px" text="Buy"/>
                <Button  profile="fdTabHit"  position="0px 0px" onClick="onTabBuy"/>
            </GuiElement>
            <GuiElement profile="fdTabContainer" id="tabSellBtn" position="74px -70px">
