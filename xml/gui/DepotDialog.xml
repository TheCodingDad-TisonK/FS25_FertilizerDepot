                <Text profile="depotCellName"  id="row7name"  position="-270px -5px" text=""/>
                <Text profile="depotCellStock" id="row7stock" position="-95px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row7price" position="60px   -5px" text=""/>
                <GuiElement profile="depotBtnContainer" id="row7buy1" position="225px 0px">
                    <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                    <Text    profile="depotBtnTxt" position="0px 0px" text="100L"/>
                    <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy7_100"/>
