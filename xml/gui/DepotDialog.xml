<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!--
    DepotDialog — FS25_FertilizerDepot
    Layout pattern: WTListDialog / CTManagementDialog (proven working).
    Key rules:
      - FLAT layout: all elements are DIRECT children of fs25_dialogContentContainer
      - Cell text profiles MUST extend fs25_textDefault (NOT fs25_dialogText)
      - Buy button containers (GuiElement wrappers) are also direct children
      - onClose NEVER named "onClose" (reserved lifecycle)
      - No $l10n_ in text attrs; tr() sets correct lang in Lua

    Column X centers (920px dialog, content center ~460px from left):
      Name   (200px): -270px  →  190px from left
      Stock  (110px):  -95px  →  365px from left
      Price  (120px):  +60px  →  520px from left
      Buy1    (65px): +225px  →  685px from left
      Buy2    (65px): +295px  →  755px from left
      Buy3    (65px): +365px  →  825px from left  (right edge ~857px, within 920px ✓)

    Row Y positions (22px spacing, starting at -88px):
      Headers: -68px
      Row 0:   -88px   Row 4: -176px
      Row 1:  -110px   Row 5: -198px
      Row 2:  -132px   Row 6: -220px
      Row 3:  -154px   Row 7: -242px
-->
<GUI onOpen="onOpen" onClose="fdOnClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="dialogBg" id="dialogElement" size="920px 580px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- ── Title / season ──────────────────────── -->
            <Text profile="depotTitle"       id="depotTitleText" position="0px   -18px" text="Fertilizer Depot"/>
            <Text profile="depotSeasonLabel" id="seasonLabel"    position="340px -22px" text=""/>

            <!-- ── Tab Buttons (3-layer) ──────────────── -->
            <GuiElement profile="fdTabContainer" id="tabBuyBtn" position="-80px -46px">
                <Bitmap  profile="fdTabBg"   position="0px 0px"/>
                <Text    profile="fdTabText" id="tabBuyText" position="0px 0px" text="Buy"/>
                <Button  profile="fdTabHit"  position="0px 0px" onClick="onTabBuy"/>
            </GuiElement>
            <GuiElement profile="fdTabContainer" id="tabSellBtn" position="80px -46px">
                <Bitmap  profile="fdTabBg"   position="0px 0px"/>
                <Text    profile="fdTabText" id="tabSellText" position="0px 0px" text="Sell"/>
                <Button  profile="fdTabHit"  position="0px 0px" onClick="onTabSell"/>
            </GuiElement>

            <!-- ── Column Headers ────────────────────── -->
            <Text profile="depotColHeader" id="colTypeHeader"  position="-270px -68px" text="Fill Type"/>
            <Text profile="depotColHeader" id="colStockHeader" position="-95px  -68px" text="Depot Stock"/>
            <Text profile="depotColHeader" id="colPriceHeader" position="60px   -68px" text="Price / 1kL"/>

            <!-- ── Divider ───────────────────────────── -->
            <Bitmap profile="depotDivider" position="0px -82px"/>

            <!-- ── Row 0 ──────────────────────────────── -->
            <Text profile="depotCellName"  id="row0name"  position="-270px -88px" text=""/>
            <Text profile="depotCellStock" id="row0stock" position="-95px  -88px" text=""/>
            <Text profile="depotCellPrice" id="row0price" position="60px   -88px" text=""/>
            <GuiElement profile="depotBtnContainer" id="row0buy1" position="225px -88px">
                <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                <Text    profile="depotBtnTxt" position="0px 0px" text="100L"/>
                <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy0_100"/>
            </GuiElement>
            <GuiElement profile="depotBtnContainer" id="row0buy2" position="295px -88px">
                <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                <Text    profile="depotBtnTxt" position="0px 0px" text="500L"/>
                <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy0_500"/>
            </GuiElement>
            <GuiElement profile="depotBtnContainer" id="row0buy3" position="365px -88px">
                <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                <Text    profile="depotBtnTxt" id="row0buy3txt" position="0px 0px" text="1kL"/>
                <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy0_1000"/>
            </GuiElement>

            <!-- ── Row 1 ──────────────────────────────── -->
            <Text profile="depotCellName"  id="row1name"  position="-270px -110px" text=""/>
            <Text profile="depotCellStock" id="row1stock" position="-95px  -110px" text=""/>
