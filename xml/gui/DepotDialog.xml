<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!--
    DepotDialog — FS25_FertilizerDepot
    Pattern: emptyPanel row containers (SoilReportDialog, proven).
    Text cells at intermediate X MUST be inside row containers.

    Row container: 860px wide, anchorTopCenter.
    Column X centres (relative to row container centre):
      Name   : -260px  (200px wide)
      Stock  :  -60px  (120px wide)
      Price  :  +80px  (120px wide)
      Button : +250px  ( 80px wide)

    Y layout (content container, anchorTopCenter):
      -18  : title          -34  : divider
      -46  : header row     -60  : divider
      -72  : row 0          -94  : row 1
      -116 : row 2          -138 : row 3
      -160 : row 4          -182 : row 5
      -204 : row 6          -226 : row 7
      -250 : pagination
      -268 : divider
      -288 : pre-order row  (buy tab only)
      -332 : status text
-->
<GUI onOpen="onOpen" onClose="fdOnClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="depotDialogBg" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- Title + season -->
            <Text profile="depotTitle"       id="depotTitleText" position="0px   -18px" text="Fertilizer Depot"/>
            <Text profile="depotSeasonLabel" id="seasonLabel"    position="340px -22px" text=""/>

            <Bitmap profile="depotDivider" position="0px -34px"/>

            <!-- Column headers -->
            <GuiElement profile="depotHeaderRow" position="0px -46px">
                <Text profile="depotColHeader" id="colTypeHeader"   position="-260px -5px" text="Fill Type"/>
                <Text profile="depotColHeader" id="colStockHeader"  position="-60px  -5px" text="Depot Stock"/>
                <Text profile="depotColHeader" id="colPriceHeader"  position="80px  -5px" text="Price / 1kL"/>
            </GuiElement>

            <Bitmap profile="depotDivider" position="0px -60px"/>

            <!-- Row 0 -->
            <GuiElement profile="depotRow" position="0px -72px">
                <Text profile="depotCellName"  id="row0name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row0stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row0price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row0action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row0actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction0"/>
                </GuiElement>
            </GuiElement>

            <!-- Row 1 -->
            <GuiElement profile="depotRow" position="0px -94px">
                <Text profile="depotCellName"  id="row1name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row1stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row1price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row1action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row1actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction1"/>
                </GuiElement>
            </GuiElement>

            <!-- Row 2 -->
            <GuiElement profile="depotRow" position="0px -116px">
                <Text profile="depotCellName"  id="row2name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row2stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row2price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row2action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row2actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction2"/>
                </GuiElement>
            </GuiElement>

            <!-- Row 3 -->
            <GuiElement profile="depotRow" position="0px -138px">
                <Text profile="depotCellName"  id="row3name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row3stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row3price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row3action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row3actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction3"/>
                </GuiElement>
            </GuiElement>

            <!-- Row 4 -->
            <GuiElement profile="depotRow" position="0px -160px">
                <Text profile="depotCellName"  id="row4name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row4stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row4price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row4action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row4actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction4"/>
                </GuiElement>
            </GuiElement>

            <!-- Row 5 -->
            <GuiElement profile="depotRow" position="0px -182px">
                <Text profile="depotCellName"  id="row5name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row5stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row5price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row5action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row5actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction5"/>
                </GuiElement>
            </GuiElement>

            <!-- Row 6 -->
            <GuiElement profile="depotRow" position="0px -204px">
                <Text profile="depotCellName"  id="row6name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row6stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row6price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row6action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row6actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction6"/>
                </GuiElement>
            </GuiElement>

            <!-- Row 7 -->
            <GuiElement profile="depotRow" position="0px -226px">
                <Text profile="depotCellName"  id="row7name"  position="-260px -5px" text=""/>
                <Text profile="depotCellStock" id="row7stock" position="-60px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row7price" position="80px  -5px" text=""/>
                <GuiElement profile="depotActionBtn" id="row7action" position="250px 0px">
                    <Bitmap  profile="depotActionBg"  position="0px 0px"/>
                    <Text    profile="depotActionTxt" id="row7actionTxt" position="0px 0px" text="Select"/>
                    <Button  profile="depotActionHit" position="0px 0px" onClick="onAction7"/>
                </GuiElement>
            </GuiElement>

            <!-- Pagination -->
            <GuiElement profile="fdPageContainer" id="prevPageBtn" position="-90px -250px">
                <Bitmap  profile="fdPageBg"  position="0px 0px"/>
                <Text    profile="fdPageTxt" position="0px 0px" text="&lt;"/>
                <Button  profile="fdPageHit" position="0px 0px" onClick="onPrevPage"/>
            </GuiElement>
            <Text profile="depotPageLabel" id="pageLabel" position="0px -251px" text="1 / 1"/>
            <GuiElement profile="fdPageContainer" id="nextPageBtn" position="90px -250px">
                <Bitmap  profile="fdPageBg"  position="0px 0px"/>
                <Text    profile="fdPageTxt" position="0px 0px" text="&gt;"/>
                <Button  profile="fdPageHit" position="0px 0px" onClick="onNextPage"/>
            </GuiElement>

            <!-- Pre-order section (visible on Buy tab only) -->
            <Bitmap profile="depotDivider" id="preOrderDivider" position="0px -268px"/>
            <GuiElement profile="depotPreOrderRow" id="preOrderRow" position="0px -288px">
                <Text profile="depotPreOrderLabel" position="-360px -5px" text="Order:"/>
                <Text profile="depotSelectedName"  id="selectedTypeName" position="-200px -5px" text="—"/>
                <GuiElement profile="depotStepContainer" id="amountMinusBtn" position="-55px 0px">
                    <Bitmap  profile="depotStepBg"  position="0px 0px"/>
                    <Text    profile="depotStepTxt" position="0px 0px" text="-500L"/>
                    <Button  profile="depotStepHit" position="0px 0px" onClick="onAmountMinus"/>
                </GuiElement>
                <Text profile="depotAmountDisplay" id="amountDisplay" position="35px -5px" text="1000L"/>
                <GuiElement profile="depotStepContainer" id="amountPlusBtn" position="130px 0px">
                    <Bitmap  profile="depotStepBg"  position="0px 0px"/>
                    <Text    profile="depotStepTxt" position="0px 0px" text="500L"/>
                    <Button  profile="depotStepHit" position="0px 0px" onClick="onAmountPlus"/>
                </GuiElement>
                <GuiElement profile="depotConfirmContainer" id="confirmOrderBtn" position="295px 0px">
                    <Bitmap  profile="depotConfirmBg"  position="0px 0px"/>
                    <Text    profile="depotConfirmTxt" position="0px 0px" text="Confirm"/>
                    <Button  profile="depotConfirmHit" position="0px 0px" onClick="onConfirmOrder"/>
                </GuiElement>
            </GuiElement>

            <!-- Products order row (visible on Products tab only) -->
            <GuiElement profile="depotProductsOrderRow" id="productsOrderRow" position="0px -288px">
                <Text profile="depotPreOrderLabel"  position="-360px -5px" text="Order:"/>
                <Text profile="depotSelectedName"   id="prodSelectedName" position="-200px -5px" text="—"/>
                <GuiElement profile="depotStepContainer" id="prodQtyMinus" position="-55px 0px">
                    <Bitmap  profile="depotStepBg"  position="0px 0px"/>
                    <Text    profile="depotStepTxt" position="0px 0px" text="&lt;"/>
                    <Button  profile="depotStepHit" position="0px 0px" onClick="onProductQtyMinus"/>
                </GuiElement>
                <Text profile="depotAmountDisplay" id="prodQtyDisplay" position="35px -5px" text="×1"/>
                <GuiElement profile="depotStepContainer" id="prodQtyPlus" position="130px 0px">
                    <Bitmap  profile="depotStepBg"  position="0px 0px"/>
                    <Text    profile="depotStepTxt" position="0px 0px" text="&gt;"/>
                    <Button  profile="depotStepHit" position="0px 0px" onClick="onProductQtyPlus"/>
                </GuiElement>
                <Text profile="depotProductPrice" id="prodTotalPrice" position="215px -5px" text=""/>
                <GuiElement profile="depotConfirmContainer" id="prodConfirm" position="320px 0px">
                    <Bitmap  profile="depotConfirmBg"  position="0px 0px"/>
                    <Text    profile="depotConfirmTxt" position="0px 0px" text="Order"/>
                    <Button  profile="depotConfirmHit" position="0px 0px" onClick="onProductConfirm"/>
                </GuiElement>
            </GuiElement>

            <!-- Order panel (visible on ORDER tab only) -->
            <GuiElement profile="depotOrderPanel" id="orderPanel" position="0px -288px">
                <Text profile="depotOrderCostText" id="orderCostText" position="-185px -5px" text=""/>
                <GuiElement profile="depotOrderBtnContainer" id="orderActionBtn" position="315px 0px">
                    <Bitmap  profile="depotOrderBtnBg"  position="0px 0px"/>
                    <Text    profile="depotOrderBtnTxt" id="orderActionTxt" position="0px 0px" text="Place Order"/>
                    <Button  profile="depotOrderBtnHit" position="0px 0px" onClick="onOrderAction"/>
                </GuiElement>
            </GuiElement>

            <!-- Status line -->
            <Text profile="depotStatusText" id="statusText" position="0px -332px" text=""/>

        </GuiElement>

        <!-- Footer: Close | Sell | Products | Buy | Order -->
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack"     id="closeButton"       text="Close"    onClick="onClickClose"/>
            <Button profile="buttonBack"     id="tabSellFooter"     text="Sell"     onClick="onTabSell"/>
            <Button profile="buttonBack"     id="tabProductsFooter" text="Products" onClick="onTabProducts"/>
            <Button profile="buttonBack"     id="tabOrderFooter"    text="Order"    onClick="onTabOrder"/>
            <Button profile="buttonActivate" id="tabBuyFooter"      text="Buy"      onClick="onTabBuy"/>
        </BoxLayout>

    </GuiElement>

    <GUIProfiles>

        <Profile name="depotDialogBg" extends="fs25_dialogBg">
            <size value="920px 520px"/>
        </Profile>

        <Profile name="depotTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="820px 24px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="depotSeasonLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 16px"/>
            <textSize value="13px"/>
            <textColor value="0.9 0.75 0.2 1"/>
            <textAlignment value="right"/>
        </Profile>

        <Profile name="depotDivider" extends="baseReference" with="anchorTopCenter">
            <size value="820px 1px"/>
            <imageColor value="0.3 0.35 0.45 0.8"/>
        </Profile>

        <!-- Row containers -->
        <Profile name="depotHeaderRow" extends="emptyPanel" with="anchorTopCenter">
            <size value="860px 20px"/>
        </Profile>
        <Profile name="depotRow" extends="emptyPanel" with="anchorTopCenter">
            <size value="860px 22px"/>
        </Profile>

        <!-- Column headers -->
        <Profile name="depotColHeader" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 14px"/>
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="0.55 0.7 0.9 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- Cell text -->
        <Profile name="depotCellName" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 18px"/>
            <textSize value="13px"/>
            <textAlignment value="left"/>
            <textColor value="1 1 1 1"/>
        </Profile>
        <Profile name="depotCellStock" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="120px 18px"/>
            <textSize value="13px"/>
            <textAlignment value="left"/>
            <textColor value="0.82 0.82 0.82 1"/>
        </Profile>
        <Profile name="depotCellPrice" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="120px 18px"/>
            <textSize value="13px"/>
            <textAlignment value="left"/>
            <textColor value="0.35 0.88 0.42 1"/>
        </Profile>

        <!-- Action button (Select / Sell All) -->
        <Profile name="depotActionBtn" extends="emptyPanel" with="anchorTopCenter">
            <size value="80px 20px"/>
        </Profile>
        <Profile name="depotActionBg" extends="baseReference" with="anchorTopCenter">
            <size value="80px 20px"/>
            <imageColor value="0.10 0.16 0.32 0.95"/>
        </Profile>
        <Profile name="depotActionTxt" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="80px 20px"/>
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="0.6 0.8 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="depotActionHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="80px 20px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Pagination -->
        <Profile name="fdPageContainer" extends="emptyPanel" with="anchorTopCenter">
            <size value="44px 22px"/>
        </Profile>
        <Profile name="fdPageBg" extends="baseReference" with="anchorTopCenter">
            <size value="44px 22px"/>
            <imageColor value="0.10 0.12 0.20 0.90"/>
        </Profile>
        <Profile name="fdPageTxt" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="44px 22px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="0.6 0.7 0.9 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="fdPageHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="44px 22px"/>
            <isFocusable value="true"/>
        </Profile>
        <Profile name="depotPageLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="80px 22px"/>
            <textSize value="12px"/>
            <textColor value="0.5 0.55 0.65 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Pre-order row -->
        <Profile name="depotPreOrderRow" extends="emptyPanel" with="anchorTopCenter">
            <size value="860px 36px"/>
        </Profile>

        <!-- Products order row (same dimensions as preOrderRow, mutual-exclusion visibility) -->
        <Profile name="depotProductsOrderRow" extends="emptyPanel" with="anchorTopCenter">
            <size value="860px 36px"/>
        </Profile>

        <!-- Total price display in products row -->
        <Profile name="depotProductPrice" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="90px 24px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textColor value="0.35 0.88 0.42 1"/>
            <textAlignment value="right"/>
        </Profile>
        <Profile name="depotPreOrderLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="60px 24px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textColor value="0.6 0.7 0.9 1"/>
            <textAlignment value="left"/>
        </Profile>
        <Profile name="depotSelectedName" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="190px 24px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- Step buttons (-500L / +500L) -->
        <Profile name="depotStepContainer" extends="emptyPanel" with="anchorTopCenter">
            <size value="65px 28px"/>
        </Profile>
        <Profile name="depotStepBg" extends="baseReference" with="anchorTopCenter">
            <size value="65px 28px"/>
            <imageColor value="0.08 0.14 0.28 0.95"/>
        </Profile>
        <Profile name="depotStepTxt" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="65px 28px"/>
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="0.7 0.85 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="depotStepHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="65px 28px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Amount display -->
        <Profile name="depotAmountDisplay" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="80px 24px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="0.35 0.88 0.42 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Confirm button -->
        <Profile name="depotConfirmContainer" extends="emptyPanel" with="anchorTopCenter">
            <size value="100px 28px"/>
        </Profile>
        <Profile name="depotConfirmBg" extends="baseReference" with="anchorTopCenter">
            <size value="100px 28px"/>
            <imageColor value="0.08 0.28 0.12 0.95"/>
        </Profile>
        <Profile name="depotConfirmTxt" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="100px 28px"/>
            <textSize value="12px"/>
            <textBold value="true"/>
            <textColor value="0.4 1 0.5 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="depotConfirmHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="100px 28px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Status text -->
        <Profile name="depotStatusText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="820px 18px"/>
            <textSize value="12px"/>
            <textColor value="0.85 0.85 0.85 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- ORDER tab panel -->
        <Profile name="depotOrderPanel" extends="emptyPanel" with="anchorTopCenter">
            <size value="860px 36px"/>
        </Profile>
        <Profile name="depotOrderCostText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="580px 28px"/>
            <textSize value="12px"/>
            <textColor value="0.82 0.82 0.82 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- ORDER action button -->
        <Profile name="depotOrderBtnContainer" extends="emptyPanel" with="anchorTopCenter">
            <size value="160px 28px"/>
        </Profile>
        <Profile name="depotOrderBtnBg" extends="baseReference" with="anchorTopCenter">
            <size value="160px 28px"/>
            <imageColor value="0.08 0.28 0.12 0.95"/>
        </Profile>
        <Profile name="depotOrderBtnTxt" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="160px 28px"/>
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="0.4 1 0.5 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="depotOrderBtnHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="160px 28px"/>
            <isFocusable value="true"/>
        </Profile>

    </GUIProfiles>

</GUI>
