                <Text profile="depotCellStock" id="row4stock" position="-95px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row4price" position="60px   -5px" text=""/>
                <GuiElement profile="depotBtnContainer" id="row4buy1" position="225px 0px">
