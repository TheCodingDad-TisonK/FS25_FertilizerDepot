                    <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy7_1000"/>
                </GuiElement>
            </GuiElement>

            <!-- ── Pagination ─────────────────────────────────────────────────────────────────── -->
            <GuiElement profile="fdPageContainer" id="prevPageBtn" position="-90px -274px">
                <Bitmap  profile="fdPageBg"  position="0px 0px"/>
                <Text    profile="fdPageTxt" position="0px 0px" text="&lt;"/>
                <Button  profile="fdPageHit" position="0px 0px" onClick="onPrevPage"/>
            </GuiElement>
            <Text profile="depotPageLabel" id="pageLabel" position="0px -275px" text="1 / 1"/>
            <GuiElement profile="fdPageContainer" id="nextPageBtn" position="90px -274px">
                <Bitmap  profile="fdPageBg"  position="0px 0px"/>
                <Text    profile="fdPageTxt" position="0px 0px" text="&gt;"/>
                <Button  profile="fdPageHit" position="0px 0px" onClick="onNextPage"/>
            </GuiElement>

            <!-- ── Status line ────────────────────────────────────────────────────────────────── -->
            <Text profile="depotStatusText" id="statusText" position="0px -298px" text=""/>

        </GuiElement>

        <!-- ── Footer ────────────────────────────────────────────────────────────────────────── -->
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack" id="closeButton" text="Close" onClick="onClickClose"/>
        </BoxLayout>

    </GuiElement>

    <!-- ── Custom Profiles ─────────────────────────────────────────────────────────────────── -->
    <GUIProfiles>

        <!-- Outer dialog bg — extends fs25_dialogBg for correct coordinate system -->
        <Profile name="depotDialogBg" extends="fs25_dialogBg">
            <size value="920px 580px"/>
        </Profile>

        <!-- Title (large, centered — direct child of content container: OK) -->
        <Profile name="depotTitle" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="820px 24px"/>
            <textSize value="20px"/>
            <textBold value="true"/>
            <textColor value="1 1 1 1"/>
            <textAlignment value="center"/>
        </Profile>

        <!-- Season label (far right — direct child, extreme X: OK) -->
        <Profile name="depotSeasonLabel" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 16px"/>
            <textSize value="13px"/>
            <textColor value="0.9 0.75 0.2 1"/>
            <textAlignment value="right"/>
        </Profile>

        <!-- Divider -->
        <Profile name="depotDivider" extends="baseReference" with="anchorTopCenter">
            <size value="820px 1px"/>
            <imageColor value="0.3 0.35 0.45 0.8"/>
        </Profile>

        <!-- Tab button container + layers -->
        <Profile name="fdTabContainer" extends="emptyPanel" with="anchorTopCenter">
            <size value="150px 28px"/>
        </Profile>
        <Profile name="fdTabBg" extends="baseReference" with="anchorTopCenter">
            <size value="150px 28px"/>
            <imageColor value="0.10 0.16 0.32 0.95"/>
        </Profile>
        <Profile name="fdTabText" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="150px 28px"/>
            <textSize value="13px"/>
            <textBold value="true"/>
            <textColor value="0.6 0.8 1 1"/>
            <textAlignment value="center"/>
        </Profile>
        <Profile name="fdTabHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="150px 28px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Row containers (SoilReportDialog pattern: emptyPanel rows inside content container).
             Text cells placed inside these rows to avoid fs25_dialogContentContainer X quirk. -->
        <Profile name="depotHeaderRow" extends="emptyPanel" with="anchorTopCenter">
            <size value="860px 20px"/>
        </Profile>
        <Profile name="depotRow" extends="emptyPanel" with="anchorTopCenter">
            <size value="860px 22px"/>
        </Profile>

        <!-- Column headers — placed inside depotHeaderRow -->
        <Profile name="depotColHeader" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 14px"/>
            <textSize value="11px"/>
            <textBold value="true"/>
            <textColor value="0.55 0.7 0.9 1"/>
            <textAlignment value="left"/>
        </Profile>

        <!-- Cell text profiles — placed inside depotRow -->
        <Profile name="depotCellName" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="200px 18px"/>
            <textSize value="13px"/>
            <textAlignment value="left"/>
            <textColor value="1 1 1 1"/>
        </Profile>
        <Profile name="depotCellStock" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="110px 18px"/>
            <textSize value="13px"/>
            <textAlignment value="left"/>
            <textColor value="0.82 0.82 0.82 1"/>
        </Profile>
        <Profile name="depotCellPrice" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="120px 18px"/>
            <textSize value="13px"/>
            <textAlignment value="left"/>
            <textColor value="0.35 0.88 0.42 1"/>
        </Profile>

        <!-- Action button container + layers — placed inside depotRow -->
        <Profile name="depotBtnContainer" extends="emptyPanel" with="anchorTopCenter">
            <size value="65px 20px"/>
        </Profile>
        <Profile name="depotBtnBg" extends="baseReference" with="anchorTopCenter">
            <size value="65px 20px"/>
            <imageColor value="0.10 0.16 0.32 0.95"/>
        </Profile>
        <Profile name="depotBtnTxt" extends="fs25_textDefault" with="anchorTopCenter">
            <size value="65px 20px"/>
            <textSize value="11px"/>
