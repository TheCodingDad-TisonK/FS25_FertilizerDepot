<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!--
    DepotDialog — FS25_FertilizerDepot
    Pattern: WTListDialog (FS25_WorkplaceTriggers) — proven working.
    Rules:
      - onClose NEVER named "onClose" (reserved lifecycle — causes double-call)
      - onCreate callback required for MessageDialog init
      - Content-area buttons MUST use 3-layer: Bitmap + Text + Button(emptyPanel+isFocusable)
      - buttonBack/buttonActivate ONLY in fs25_dialogButtonBox footer
      - No $l10n_ in text attrs (hardcode English; tr() sets correct lang in Lua)
-->
<GUI onOpen="onOpen" onClose="fdOnClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="dialogBg" id="dialogElement" size="750px 520px">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- ── Title ─────────────────────────────── -->
            <Text profile="fs25_dialogTitle" id="depotTitleText"
                  position="0px -28px" text="Fertilizer Depot"/>

            <Text profile="depotSeasonLabel" id="seasonLabel"
                  position="320px -34px" text=""/>

            <!-- ── Tab Buttons (3-layer) ──────────────── -->
