            <textAlignment value="center"/>
        </Profile>
        <Profile name="depotBtnHit" extends="emptyPanel" with="anchorTopCenter">
            <size value="65px 20px"/>
            <isFocusable value="true"/>
        </Profile>

        <!-- Pagination (direct children at extreme/center X: OK) -->
