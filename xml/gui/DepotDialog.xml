<?xml version="1.0" encoding="utf-8" standalone="no"?>
<GUI onOpen="onOpen" onClose="onClose">

    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="depotDialogBg" id="dialogElement">

        <!-- Required frame panels -->
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- ── Title Row ─────────────────────────────── -->
            <Text profile="fs25_dialogTitle" id="depotTitleText"
                  position="0px -28px" text="Fertilizer Depot"/>

            <Text profile="depotSeasonLabel" id="seasonLabel"
                  position="320px -34px" text="Summer"/>

            <!-- ── Tab Buttons ───────────────────────────── -->
            <BoxLayout profile="depotTabBox" position="0px -70px">
                <Button profile="depotTabBtn" id="tabBuyBtn"
                        text="$l10n_fd_depot_buy" onClick="onTabBuy"/>
                <Button profile="depotTabBtn" id="tabSellBtn"
                        text="$l10n_fd_depot_sell" onClick="onTabSell"/>
            </BoxLayout>

            <!-- ── Column Headers ────────────────────────── -->
            <GuiElement profile="depotHeaderRow" id="buyHeaderRow" position="0px -100px">
                <Text profile="depotColHeader" position="0px 0px"    text="$l10n_fd_col_type"/>
                <Text profile="depotColHeader" position="210px 0px"  text="$l10n_fd_col_stock"/>
                <Text profile="depotColHeader" position="340px 0px"  text="$l10n_fd_col_price"/>
                <Text profile="depotColHeader" position="500px 0px"  text=""/>
            </GuiElement>

            <!-- ── Fill Type Rows (8 slots) ──────────────── -->

            <!-- Row 0 -->
            <GuiElement profile="depotRow" id="row0" position="0px -120px">
                <Text  profile="depotCellName"  id="row0name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row0stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row0price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row0buy1"  position="490px 0px" text="100L" onClick="onBuy0_100"/>
                <Button profile="depotBtnSmall" id="row0buy2"  position="560px 0px" text="500L" onClick="onBuy0_500"/>
                <Button profile="depotBtnSmall" id="row0buy3"  position="630px 0px" text="1kL"  onClick="onBuy0_1000"/>
            </GuiElement>

            <!-- Row 1 -->
            <GuiElement profile="depotRow" id="row1" position="0px -150px">
                <Text  profile="depotCellName"  id="row1name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row1stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row1price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row1buy1"  position="490px 0px" text="100L" onClick="onBuy1_100"/>
                <Button profile="depotBtnSmall" id="row1buy2"  position="560px 0px" text="500L" onClick="onBuy1_500"/>
                <Button profile="depotBtnSmall" id="row1buy3"  position="630px 0px" text="1kL"  onClick="onBuy1_1000"/>
            </GuiElement>

            <!-- Row 2 -->
            <GuiElement profile="depotRow" id="row2" position="0px -180px">
                <Text  profile="depotCellName"  id="row2name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row2stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row2price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row2buy1"  position="490px 0px" text="100L" onClick="onBuy2_100"/>
                <Button profile="depotBtnSmall" id="row2buy2"  position="560px 0px" text="500L" onClick="onBuy2_500"/>
                <Button profile="depotBtnSmall" id="row2buy3"  position="630px 0px" text="1kL"  onClick="onBuy2_1000"/>
            </GuiElement>

            <!-- Row 3 -->
            <GuiElement profile="depotRow" id="row3" position="0px -210px">
                <Text  profile="depotCellName"  id="row3name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row3stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row3price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row3buy1"  position="490px 0px" text="100L" onClick="onBuy3_100"/>
                <Button profile="depotBtnSmall" id="row3buy2"  position="560px 0px" text="500L" onClick="onBuy3_500"/>
                <Button profile="depotBtnSmall" id="row3buy3"  position="630px 0px" text="1kL"  onClick="onBuy3_1000"/>
            </GuiElement>

            <!-- Row 4 -->
            <GuiElement profile="depotRow" id="row4" position="0px -240px">
                <Text  profile="depotCellName"  id="row4name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row4stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row4price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row4buy1"  position="490px 0px" text="100L" onClick="onBuy4_100"/>
                <Button profile="depotBtnSmall" id="row4buy2"  position="560px 0px" text="500L" onClick="onBuy4_500"/>
                <Button profile="depotBtnSmall" id="row4buy3"  position="630px 0px" text="1kL"  onClick="onBuy4_1000"/>
            </GuiElement>

            <!-- Row 5 -->
            <GuiElement profile="depotRow" id="row5" position="0px -270px">
                <Text  profile="depotCellName"  id="row5name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row5stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row5price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row5buy1"  position="490px 0px" text="100L" onClick="onBuy5_100"/>
                <Button profile="depotBtnSmall" id="row5buy2"  position="560px 0px" text="500L" onClick="onBuy5_500"/>
                <Button profile="depotBtnSmall" id="row5buy3"  position="630px 0px" text="1kL"  onClick="onBuy5_1000"/>
            </GuiElement>

            <!-- Row 6 -->
            <GuiElement profile="depotRow" id="row6" position="0px -300px">
                <Text  profile="depotCellName"  id="row6name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row6stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row6price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row6buy1"  position="490px 0px" text="100L" onClick="onBuy6_100"/>
                <Button profile="depotBtnSmall" id="row6buy2"  position="560px 0px" text="500L" onClick="onBuy6_500"/>
                <Button profile="depotBtnSmall" id="row6buy3"  position="630px 0px" text="1kL"  onClick="onBuy6_1000"/>
            </GuiElement>

            <!-- Row 7 -->
            <GuiElement profile="depotRow" id="row7" position="0px -330px">
                <Text  profile="depotCellName"  id="row7name"  position="0px 0px"   text=""/>
                <Text  profile="depotCellValue" id="row7stock" position="210px 0px" text=""/>
                <Text  profile="depotCellValue" id="row7price" position="340px 0px" text=""/>
                <Button profile="depotBtnSmall" id="row7buy1"  position="490px 0px" text="100L" onClick="onBuy7_100"/>
                <Button profile="depotBtnSmall" id="row7buy2"  position="560px 0px" text="500L" onClick="onBuy7_500"/>
                <Button profile="depotBtnSmall" id="row7buy3"  position="630px 0px" text="1kL"  onClick="onBuy7_1000"/>
            </GuiElement>

            <!-- ── Sell Tab Row (reuses same row slots, different action) ── -->

            <!-- ── Pagination ─────────────────────────────── -->
            <BoxLayout profile="depotPageBox" position="0px -380px">
                <Button profile="depotBtnPage" id="prevPageBtn"
                        text="◀" onClick="onPrevPage"/>
                <Text profile="depotPageLabel" id="pageLabel" text="1 / 1"/>
                <Button profile="depotBtnPage" id="nextPageBtn"
                        text="▶" onClick="onNextPage"/>
            </BoxLayout>

            <!-- ── Status / Info line ──────────────────────── -->
            <Text profile="depotStatusText" id="statusText"
                  position="0px -415px" text=""/>

        </GuiElement>

        <!-- ── Footer Buttons ────────────────────────────── -->
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack" id="closeButton"
                    text="$l10n_fd_depot_close" onClick="onClose"/>
        </BoxLayout>

    </GuiElement>

    <!-- ── Custom Profiles ──────────────────────────────── -->
    <GUIProfiles>

        <Profile name="depotDialogBg" extends="fs25_dialogBg">
            <size value="750px 520px"/>
        </Profile>

        <Profile name="depotSeasonLabel" extends="fs25_dialogText">
            <textSize value="14px"/>
            <textColor value="0.9 0.75 0.2 1"/>
            <textAlignment value="right"/>
        </Profile>

        <Profile name="depotTabBox" extends="emptyPanel" with="anchorTopCenter">
            <size value="300px 32px"/>
            <flowDirection value="horizontal"/>
            <alignmentX value="center"/>
            <elementSpacing value="8px"/>
        </Profile>

        <Profile name="depotTabBtn" extends="buttonOK">
            <size value="140px 28px"/>
            <textSize value="13px"/>
        </Profile>

        <Profile name="depotHeaderRow" extends="emptyPanel">
            <size value="710px 18px"/>
        </Profile>

        <Profile name="depotColHeader" extends="fs25_dialogText">
            <textSize value="12px"/>
            <textBold value="true"/>
            <textColor value="0.7 0.7 0.7 1"/>
        </Profile>

        <Profile name="depotRow" extends="emptyPanel">
            <size value="710px 24px"/>
        </Profile>

        <Profile name="depotCellName" extends="fs25_dialogText">
            <textSize value="13px"/>
            <size value="200px 24px"/>
            <textAlignment value="left"/>
        </Profile>

        <Profile name="depotCellValue" extends="fs25_dialogText">
            <textSize value="13px"/>
            <size value="120px 24px"/>
            <textAlignment value="right"/>
        </Profile>

        <Profile name="depotBtnSmall" extends="buttonActivate">
            <size value="60px 22px"/>
            <textSize value="11px"/>
        </Profile>

        <Profile name="depotPageBox" extends="emptyPanel" with="anchorTopCenter">
            <size value="200px 28px"/>
            <flowDirection value="horizontal"/>
            <alignmentX value="center"/>
            <elementSpacing value="10px"/>
        </Profile>

        <Profile name="depotBtnPage" extends="buttonBack">
            <size value="40px 26px"/>
            <textSize value="13px"/>
        </Profile>

        <Profile name="depotPageLabel" extends="fs25_dialogText">
            <textSize value="13px"/>
            <size value="80px 26px"/>
            <textAlignment value="center"/>
        </Profile>

        <Profile name="depotStatusText" extends="fs25_dialogText">
            <textSize value="12px"/>
            <textColor value="0.85 0.85 0.85 1"/>
            <size value="700px 20px"/>
            <textAlignment value="center"/>
        </Profile>

    </GUIProfiles>

</GUI>
