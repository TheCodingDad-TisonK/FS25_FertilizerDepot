                <Text    profile="fdTabText" id="tabSellText" position="0px 0px" text="Sell"/>
                <Button  profile="fdTabHit"  position="0px 0px" onClick="onTabSell"/>
            </GuiElement>

            <!-- ── Column Headers ────────────────────── -->
            <Text profile="depotColHeader" id="colTypeHeader"  position="-250px -100px" text="Fill Type"/>
            <Text profile="depotColHeader" id="colStockHeader" position="-40px  -100px" text="Depot Stock"/>
            <Text profile="depotColHeader" id="colPriceHeader" position="110px  -100px" text="Price / 1kL"/>

            <!-- ── Row 0 ──────────────────────────────── -->
