<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!--
    DepotDialog — FS25_FertilizerDepot
    Layout pattern: SoilReportDialog (proven working).
    KEY RULE: Text cells at intermediate X positions MUST be inside an emptyPanel
              row container — direct children of fs25_dialogContentContainer break
              at non-extreme X values. Only Bitmap/GuiElement decorators placed directly.

    Column X centers (relative to row container center):
      Name   (200px): -270px
      Stock  (110px):  -95px
      Price  (120px):  +60px
      Buy1    (65px): +225px
      Buy2    (65px): +295px
      Buy3    (65px): +365px

    Row container: depotRow = emptyPanel, 860px wide, 22px tall
    Row Y positions (content container coords):
      Headers: -68px
      Row 0:   -92px    Row 4: -180px
      Row 1:  -114px    Row 5: -202px
      Row 2:  -136px    Row 6: -224px
      Row 3:  -158px    Row 7: -246px
      Pagination: -274px
      Status:     -298px
-->
<GUI onOpen="onOpen" onClose="fdOnClose" onCreate="onCreate">
    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="depotDialogBg" id="dialogElement">
        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- ── Title / season (direct children of content container: centered or extreme X) ── -->
            <Text profile="depotTitle"       id="depotTitleText" position="0px   -18px" text="Fertilizer Depot"/>
            <Text profile="depotSeasonLabel" id="seasonLabel"    position="340px -22px" text=""/>

            <!-- ── Tab Buttons ──────────────────────────────────────────────────────────────────── -->
            <GuiElement profile="fdTabContainer" id="tabBuyBtn" position="-80px -46px">
                <Bitmap  profile="fdTabBg"   position="0px 0px"/>
                <Text    profile="fdTabText" id="tabBuyText" position="0px 0px" text="Buy"/>
                <Button  profile="fdTabHit"  position="0px 0px" onClick="onTabBuy"/>
            </GuiElement>
            <GuiElement profile="fdTabContainer" id="tabSellBtn" position="80px -46px">
                <Bitmap  profile="fdTabBg"   position="0px 0px"/>
                <Text    profile="fdTabText" id="tabSellText" position="0px 0px" text="Sell"/>
                <Button  profile="fdTabHit"  position="0px 0px" onClick="onTabSell"/>
            </GuiElement>

            <!-- ── Divider ─────────────────────────────────────────────────────────────────────── -->
            <Bitmap profile="depotDivider" position="0px -60px"/>

            <!-- ── Column Headers row ──────────────────────────────────────────────────────────── -->
            <GuiElement profile="depotHeaderRow" position="0px -68px">
                <Text profile="depotColHeader" id="colTypeHeader"  position="-270px -5px" text="Fill Type"/>
                <Text profile="depotColHeader" id="colStockHeader" position="-95px  -5px" text="Depot Stock"/>
                <Text profile="depotColHeader" id="colPriceHeader" position="60px   -5px" text="Price / 1kL"/>
            </GuiElement>

            <!-- ── Divider under headers ───────────────────────────────────────────────────────── -->
            <Bitmap profile="depotDivider" position="0px -82px"/>

            <!-- ── Row 0 ──────────────────────────────────────────────────────────────────────── -->
            <GuiElement profile="depotRow" position="0px -92px">
                <Text profile="depotCellName"  id="row0name"  position="-270px -5px" text=""/>
                <Text profile="depotCellStock" id="row0stock" position="-95px  -5px" text=""/>
                <Text profile="depotCellPrice" id="row0price" position="60px   -5px" text=""/>
                <GuiElement profile="depotBtnContainer" id="row0buy1" position="225px 0px">
                    <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                    <Text    profile="depotBtnTxt" position="0px 0px" text="100L"/>
                    <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy0_100"/>
                </GuiElement>
                <GuiElement profile="depotBtnContainer" id="row0buy2" position="295px 0px">
                    <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                    <Text    profile="depotBtnTxt" position="0px 0px" text="500L"/>
                    <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy0_500"/>
                </GuiElement>
                <GuiElement profile="depotBtnContainer" id="row0buy3" position="365px 0px">
                    <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                    <Text    profile="depotBtnTxt" id="row0buy3txt" position="0px 0px" text="1kL"/>
                    <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy0_1000"/>
                </GuiElement>
            </GuiElement>

            <!-- ── Row 1 ──────────────────────────────────────────────────────────────────────── -->
