                <Text    profile="depotCellValue" id="row0stock"   position="-40px  0px" text=""/>
                <Text    profile="depotCellValue" id="row0price"   position="110px  0px" text=""/>
                <GuiElement profile="depotBtnContainer" id="row0buy1" position="250px 0px">
                    <Bitmap  profile="depotBtnBg"  position="0px 0px"/>
                    <Text    profile="depotBtnTxt" position="0px 0px" text="100L"/>
                    <Button  profile="depotBtnHit" position="0px 0px" onClick="onBuy0_100"/>
