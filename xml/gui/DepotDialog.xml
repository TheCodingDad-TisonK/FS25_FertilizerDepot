            <Text profile="depotCellStock" id="row7stock" position="-95px  -242px" text=""/>
            <Text profile="depotCellPrice" id="row7price" position="60px   -242px" text=""/>
            <GuiElement profile="depotBtnContainer" id="row7buy1" position="225px -242px">
