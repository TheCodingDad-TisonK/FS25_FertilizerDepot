<?xml version="1.0" encoding="utf-8" standalone="no"?>
<GUI onOpen="onOpen" onClose="fdSettingsOnClose" onCreate="onCreate">

    <GuiElement profile="newLayer"/>
    <Bitmap profile="dialogFullscreenBg" id="dialogBg"/>

    <GuiElement profile="depotSettingsBg" id="dialogElement">

        <ThreePartBitmap profile="fs25_dialogBgMiddle"/>
        <ThreePartBitmap profile="fs25_dialogBgTop"/>
        <ThreePartBitmap profile="fs25_dialogBgBottom"/>

        <GuiElement profile="fs25_dialogContentContainer">

            <!-- Title -->
            <Text profile="fs25_dialogTitle" id="settingsTitleText"
                  position="0px -28px" text="$l10n_fd_settings_title"/>

            <!-- Admin-only notice (hidden for admin/server) -->
            <Text profile="depotAdminBadge" id="adminBadge"
                  position="0px -52px" text="$l10n_fd_settings_admin_only"/>

            <!-- Seasonal Pricing -->
            <Text    profile="depotSettingsLabel"  position="-150px -90px"  text="$l10n_fd_settings_seasonal"/>
            <MultiTextOption profile="depotSettingsOption" id="optSeasonalPricing"
                             position="150px -90px" onChanged="onSeasonalPricingChanged"/>

            <!-- Storage Capacity -->
            <Text    profile="depotSettingsLabel"  position="-150px -130px" text="$l10n_fd_settings_capacity"/>
            <MultiTextOption profile="depotSettingsOption" id="optStorageCapacity"
                             position="150px -130px" onChanged="onStorageCapacityChanged"/>

            <!-- Sell Ratio -->
            <Text    profile="depotSettingsLabel"  position="-150px -170px" text="$l10n_fd_settings_sell_ratio"/>
            <MultiTextOption profile="depotSettingsOption" id="optSellRatio"
                             position="150px -170px" onChanged="onSellRatioChanged"/>

            <!-- Buy Price Multiplier -->
            <Text    profile="depotSettingsLabel"  position="-150px -210px" text="$l10n_fd_settings_buy_mult"/>
            <MultiTextOption profile="depotSettingsOption" id="optBuyMultiplier"
                             position="150px -210px" onChanged="onBuyMultiplierChanged"/>

            <!-- Debug Logging -->
            <Text    profile="depotSettingsLabel"  position="-150px -250px" text="$l10n_fd_settings_debug"/>
            <MultiTextOption profile="depotSettingsOption" id="optDebugLogging"
                             position="150px -250px" onChanged="onDebugLoggingChanged"/>

        </GuiElement>

        <!-- Footer buttons -->
        <BoxLayout profile="fs25_dialogButtonBox">
            <Button profile="buttonBack"     text="$l10n_fd_settings_reset"
                    onClick="onResetDefaults"/>
            <Button profile="buttonActivate" text="$l10n_fd_settings_apply"
                    onClick="onApplySettings"/>
            <Button profile="buttonBack"     text="$l10n_fd_depot_close"
                    onClick="onCloseSettings"/>
        </BoxLayout>

    </GuiElement>

    <GUIProfiles>

        <Profile name="depotSettingsBg" extends="fs25_dialogBg">
            <size value="720px 380px"/>
        </Profile>

        <Profile name="depotAdminBadge" extends="fs25_dialogText" with="anchorTopCenter">
            <textSize value="12px"/>
            <textColor value="1 0.4 0.4 1"/>
            <textAlignment value="center"/>
            <size value="600px 16px"/>
        </Profile>

        <Profile name="depotSettingsLabel" extends="fs25_dialogText" with="anchorTopCenter">
            <textSize value="14px"/>
            <textAlignment value="left"/>
            <size value="280px 32px"/>
        </Profile>

        <Profile name="depotSettingsOption" extends="multiTextOption" with="anchorTopCenter">
            <size value="240px 32px"/>
        </Profile>

    </GUIProfiles>

</GUI>
